[Unit]
Description=Weekly Reporter - Personal weekly report editor
Documentation=https://github.com/weekly-reporter
After=network.target

[Service]
Type=simple
WorkingDirectory=%h/github/weekly-reporter
ExecStart=/home/god/.nvm/versions/node/v24.13.0/bin/npm run start
Restart=on-failure
RestartSec=10
StartLimitIntervalSec=60
StartLimitBurst=3
StandardOutput=journal
StandardError=journal

# Environment
Environment=NODE_ENV=production
Environment=PORT=6868
Environment=HOSTNAME=0.0.0.0
Environment=XDG_DATA_HOME=%h/.local/share
Environment=XDG_CONFIG_HOME=%h/.config

# Security
NoNewPrivileges=true
PrivateTmp=true

[Install]
WantedBy=default.target